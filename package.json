{
  "name": "app",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "demo:concurrency": "tsx src/scripts/concurrency-demo.ts",
    "test": "vitest",
    "test:run": "vitest run --pool vmThreads",
    "test:watch": "vitest --pool vmThreads",
    "migrate:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "migrate:up": "drizzle-kit migrate --config=drizzle.config.ts",
    "migrate:down": "drizzle-kit migrate:rollback --config=drizzle.config.ts",
    "migrate:push": "drizzle-kit push --config=drizzle.config.ts",
    "migrate:test": "drizzle-kit migrate --config=drizzle.test.config.ts",
    "migrate:push:test": "drizzle-kit push --config=drizzle.test.config.ts",
    "studio": "drizzle-kit studio --config=drizzle.config.ts",
    "studio:test": "drizzle-kit studio --config=drizzle.test.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "^1.2.3",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.10.4",
    "@supabase/supabase-js": "^2.100.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.9",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "supabase": "^2.84.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1"
  }
}
